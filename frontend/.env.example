NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI free tools (hashtag/title/description/idea/username/bio generators)
# Used server-side by /api/ai-generate. Without it, AI tools return a friendly 503.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (defaults to claude-3-5-haiku-latest)
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Live transcript/summarizer free tools (server-side proxy to the Captapi API).
# Use one of your own capt_live_ keys; its credits power the public tools.
# Without it, those tools show a friendly "temporarily unavailable" message.
CAPTAPI_TOOL_API_KEY=capt_live_...
