NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paddle.js client-side token for overlay checkout (Paddle dashboard >
# Developer tools > Authentication > Client-side tokens). Safe to expose.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
NEXT_PUBLIC_PADDLE_ENV=sandbox   # sandbox | production

# AI free tools (hashtag/title/description/idea/username/bio generators)
# Used server-side by /api/ai-generate. Without it, AI tools return a friendly 503.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (defaults to claude-3-5-haiku-latest)
ANTHROPIC_MODEL=claude-haiku-4-5

# Live transcript/summarizer free tools (server-side proxy to the Captapi API).
# Use one of your own capt_live_ keys; its credits power the public tools.
# Without it, those tools show a friendly "temporarily unavailable" message.
CAPTAPI_TOOL_API_KEY=capt_live_...
# Optional shared secret with the API (TOOL_PROXY_SECRET). Enables Redis daily
# IP limits for the public TikTok transcript tool (in addition to the cookie gate).
CAPTAPI_TOOL_PROXY_SECRET=replace-with-a-long-random-secret

# AI image generation for /tools/youtube-thumbnail-maker.
# Used server-side by /api/thumbnail-generate. Without it, the AI thumbnail tool returns 503.
GEMINI_API_KEY=AIza...
# Optional: override Gemini image model (defaults to gemini-2.5-flash-image).
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Blog admin API used by the scheduled SEO agent.
BLOG_ADMIN_SECRET=replace-with-a-long-random-secret
# Optional: protects the legacy Outrank webhook.
OUTRANK_WEBHOOK_SECRET=replace-with-a-different-long-random-secret
