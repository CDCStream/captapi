# =====================================================
# Application
# =====================================================
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
APP_BASE_URL=http://localhost:8000

# =====================================================
# Supabase
# =====================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_ANON_KEY=eyJhbGc...

# =====================================================
# Apify
# =====================================================
APIFY_TOKEN=apify_api_...
# Let legitimate long-running actors finish; endpoint fallbacks handle unstable
# upstreams instead of cutting valid actor runs short.
APIFY_SYNC_TIMEOUT_SECONDS=120
APIFY_SYNC_MAX_ATTEMPTS=1
APIFY_SYNC_RETRY_MAX_WAIT_SECONDS=3
MCP_TOOL_TIMEOUT_SECONDS=120

# Per-platform actor IDs (override if you fork actors)
# Transcript: primary + fallback timestamped actors (run independently for
# resilience). The legacy single var below is unused by the transcript path.
APIFY_ACTOR_YT_TRANSCRIPT_1=scrape-creators/best-youtube-transcripts-scraper
APIFY_ACTOR_YT_TRANSCRIPT_2=automation-lab/youtube-transcript
APIFY_ACTOR_YOUTUBE_TRANSCRIPT=pintostudio/youtube-transcript-scraper
APIFY_ACTOR_YOUTUBE_VIDEO=streamers/youtube-scraper
APIFY_ACTOR_YOUTUBE_COMMENTS=streamers/youtube-comments-scraper
APIFY_ACTOR_YOUTUBE_SEARCH=apify/youtube-scraper
APIFY_ACTOR_YOUTUBE_PLAYLIST=powerai/youtube-playlist-videos-scraper
APIFY_ACTOR_YOUTUBE_PLAYLIST_FALLBACK=streamers/youtube-scraper
APIFY_ACTOR_YOUTUBE_CHANNEL=streamers/youtube-channel-scraper
# Download: primary (fast) + fallback (slower, used only if primary returns no link).
APIFY_ACTOR_YOUTUBE_DOWNLOAD=api-ninja/youtube-video-downloader
APIFY_ACTOR_YOUTUBE_DOWNLOAD_FALLBACK=streamers/youtube-video-downloader

APIFY_ACTOR_TIKTOK=clockworks/tiktok-scraper
APIFY_ACTOR_TIKTOK_COMMENTS=clockworks/tiktok-comments-scraper
APIFY_ACTOR_TIKTOK_COMMENT_REPLIES_FAST=automation-lab/tiktok-comments-scraper
APIFY_ACTOR_TIKTOK_PROFILE=clockworks/tiktok-profile-scraper
APIFY_ACTOR_TIKTOK_SEARCH=clockworks/tiktok-search-scraper
APIFY_ACTOR_TIKTOK_MUSIC=coregent/tiktok-sound-music-scraper
APIFY_ACTOR_TIKTOK_MUSIC_POSTS=powerai/tiktok-music-posts-video-scraper
APIFY_ACTOR_TIKTOK_MUSIC_FALLBACK=clockworks/tiktok-sound-scraper
APIFY_ACTOR_TIKTOK_SONG=apidojo/tiktok-music-scraper
APIFY_ACTOR_TIKTOK_SONG_FAST_FALLBACK=coregent/tiktok-sound-music-scraper

APIFY_ACTOR_INSTAGRAM=apify/instagram-scraper
APIFY_ACTOR_INSTAGRAM_FALLBACK=apify/instagram-scraper
APIFY_ACTOR_INSTAGRAM_REEL=apify/instagram-scraper
APIFY_ACTOR_INSTAGRAM_REEL_FALLBACK=apify/instagram-scraper
APIFY_ACTOR_INSTAGRAM_PROFILE=apify/instagram-profile-scraper
APIFY_ACTOR_INSTAGRAM_POST=apify/instagram-post-scraper
APIFY_ACTOR_INSTAGRAM_COMMENT=apify/instagram-comment-scraper
APIFY_ACTOR_INSTAGRAM_TRANSCRIPT=crawlerbros/instagram-transcript-scraper
# Use native captions first for speed. Set to auto/whisper if broader coverage is worth slower calls.
APIFY_INSTAGRAM_TRANSCRIPT_METHOD=native

APIFY_ACTOR_FACEBOOK_POSTS=apify/facebook-posts-scraper
APIFY_ACTOR_FACEBOOK_PAGES=apify/facebook-pages-scraper
APIFY_ACTOR_FACEBOOK_COMMENTS=apify/facebook-comments-scraper
APIFY_ACTOR_FACEBOOK_MARKETPLACE=unseenuser/fb-marketplace
APIFY_ACTOR_FACEBOOK_EVENTS=apify/facebook-events-scraper
APIFY_ACTOR_FACEBOOK_EVENT_DETAILS=crawlerbros/facebook-events-scraper
APIFY_ACTOR_FACEBOOK_PHOTOS=apify/facebook-photos-scraper
APIFY_ACTOR_TIKTOK_LIVE=unseenuser/tiktok-live-status-scraper
APIFY_ACTOR_TIKTOK_SEARCH_SUGGESTIONS=automation-lab/tiktok-keywords-discovery
APIFY_ACTOR_TIKTOK_POPULAR_CREATORS=scraperx/tiktok-trending-creator-scraper
APIFY_ACTOR_TIKTOK_POPULAR_CREATORS_FALLBACK=burbn/tiktok-trending-creators
# Optional: only set after validating cost/input schema for richer age/gender distributions.
# APIFY_ACTOR_TIKTOK_AUDIENCE=apricot_blackberry/tiktok-audience-builder
APIFY_ACTOR_THREADS_SEARCH=automation-lab/threads-scraper
APIFY_ACTOR_TWITTER_COMMUNITY=scrape.badger/twitter-community-scraper
APIFY_ACTOR_REDDIT_COMMUNITY=truefetch/reddit-community-profile

APIFY_ACTOR_TWITTER_TWEET=apidojo/tweet-scraper
APIFY_ACTOR_TWITTER_PROFILE=apidojo/twitter-user-scraper
APIFY_ACTOR_REDDIT=trudax/reddit-scraper-lite
APIFY_ACTOR_THREADS=igview-owner/threads-user-media-scraper
APIFY_ACTOR_THREADS_POST=easyapi/threads-post-media-downloader
APIFY_ACTOR_PINTEREST=crawlerbros/pinterest-scraper-pro
APIFY_ACTOR_INSTAGRAM_TRENDING=agentx/instagram-trending-scraper
APIFY_ACTOR_YOUTUBE_TRENDING=app.tanalytics/youtube-trending-videos
APIFY_ACTOR_YOUTUBE_SHORTS=khadinakbar/youtube-shorts-scraper
APIFY_ACTOR_LINKEDIN_PROFILE=apimaestro/linkedin-profile-detail
APIFY_ACTOR_LINKEDIN_COMPANY=apimaestro/linkedin-company-detail
APIFY_ACTOR_LINKEDIN_POST=apimaestro/linkedin-post-detail
APIFY_ACTOR_LINKEDIN_COMPANY_POSTS=automation-lab/linkedin-company-posts-scraper
APIFY_ACTOR_LINKEDIN_POST_SEARCH=apimaestro/linkedin-posts-search-scraper-no-cookies
APIFY_ACTOR_RUMBLE=kawsar/rumble-video-extractor
APIFY_ACTOR_RUMBLE_COMMENTS=thescrapelab/apify-rumble-scraper
APIFY_ACTOR_RUMBLE_TRANSCRIPT=bulletproof/rumble-transcript-extractor
APIFY_ACTOR_GOOGLE_SEARCH=apify/google-search-scraper
APIFY_ACTOR_TWITCH=maximedupre/twitch-scraper
APIFY_ACTOR_TWITCH_URL=abotapi/twitch-scraper
APIFY_ACTOR_SPOTIFY_SEARCH=apiharvest/spotify-search-all-types
APIFY_ACTOR_SPOTIFY_DETAILS=apiharvest/spotify-scraper-get-full-details
APIFY_ACTOR_SOUNDCLOUD=automation-lab/soundcloud-scraper
APIFY_ACTOR_SNAPCHAT_PROFILE=crawlerbros/snapchat-profile-scraper
APIFY_ACTOR_TRUTH_SOCIAL=simpleapi/truth-social-scraper
APIFY_ACTOR_TRUTH_SOCIAL_FALLBACK=automation-lab/truth-social-scraper
APIFY_ACTOR_KICK=scrapestorm/kick-videos-clips-scraper-cheap
APIFY_ACTOR_AMAZON_SHOP=piotrv1001/amazon-storefront-scraper
APIFY_ACTOR_AGE_GENDER=parseforge/agify-name-demographics-scraper
APIFY_ACTOR_KWAI=sian.agency/kwai-kuaishou-scraper
APIFY_ACTOR_TIKTOK_SHOP=unseenuser/tiktok-shop-scraper
APIFY_ACTOR_FACEBOOK_AD_LIBRARY=scrapemint/facebook-ads-library-scraper
APIFY_ACTOR_FACEBOOK_AD_LIBRARY_V2=apify/facebook-ads-scraper
APIFY_ACTOR_TIKTOK_AD_LIBRARY=brilliant_gum/tiktok-ads-library-scraper
APIFY_ACTOR_TIKTOK_AD_LIBRARY_DETAIL=jy-labs/tiktok-ad-library-fast-search
APIFY_ACTOR_TIKTOK_AD_LIBRARY_DETAIL_FALLBACK=prodiger/tiktok-ads-library-scraper
APIFY_ACTOR_GOOGLE_AD_LIBRARY=automation-lab/google-ads-scraper
APIFY_ACTOR_GOOGLE_AD_LIBRARY_V2=unseenuser/google-ads
APIFY_ACTOR_LINKEDIN_AD_LIBRARY=s-r/linkedin-ads-library
APIFY_ACTOR_LINKEDIN_AD_LIBRARY_DETAIL=elliotpadfield/linkedin-ad-library-scraper
APIFY_ACTOR_LINKEDIN_AD_LIBRARY_DETAIL_FALLBACK=silentflow/linkedin-ads-scraper

# Optional: increases GitHub public API rate limits for /v1/github endpoints.
GITHUB_TOKEN=

# =====================================================
# OpenAI
# =====================================================
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_SUMMARY=gpt-4o-mini
OPENAI_MODEL_TRANSCRIPTION=whisper-1

# =====================================================
# Dodo Payments (Merchant of Record)
# =====================================================
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode   # test_mode | live_mode

# Subscription product IDs (create these in the Dodo dashboard)
DODO_PRODUCT_STARTER_MONTHLY=prod_...
DODO_PRODUCT_STARTER_YEARLY=prod_...
DODO_PRODUCT_PRO_MONTHLY=prod_...
DODO_PRODUCT_PRO_YEARLY=prod_...
DODO_PRODUCT_BUSINESS_MONTHLY=prod_...
DODO_PRODUCT_BUSINESS_YEARLY=prod_...

# One-time PAYG credit pack product IDs (2k / 10k / 50k credits)
DODO_PRODUCT_PACK_STARTER=prod_...
DODO_PRODUCT_PACK_GROWTH=prod_...
DODO_PRODUCT_PACK_SCALE=prod_...

# =====================================================
# Redis (Upstash)
# =====================================================
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# =====================================================
# Limits
# =====================================================
CACHE_TTL_SECONDS=86400
RATE_LIMIT_PER_MINUTE=60
# Per-plan request-per-minute limits (must match the pricing page)
RATE_LIMIT_FREE=40
RATE_LIMIT_STARTER=120
RATE_LIMIT_PRO=300
RATE_LIMIT_BUSINESS=600
MAX_VIDEO_UPLOAD_MB=200
MAX_VIDEO_DURATION_MINUTES=60

# =====================================================
# Observability
# =====================================================
SENTRY_DSN=
LOG_LEVEL=INFO

# =====================================================
# Transactional email (Resend)
# =====================================================
RESEND_API_KEY=
EMAIL_FROM=Captapi <no-reply@captapi.com>
FRONTEND_URL=http://localhost:3000
