{
  "title": "Captapi input",
  "description": "Bring your own Captapi API key and pick an operation. This Actor calls the Captapi REST API (it does not scrape) and returns the structured result.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "apiKey": {
      "title": "Captapi API key",
      "type": "string",
      "description": "Your capt_live_... key from https://captapi.com/dashboard/api-keys. Stored encrypted. Credits are billed to your own Captapi account.",
      "editor": "textfield",
      "isSecret": true
    },
    "operation": {
      "title": "Operation",
      "type": "string",
      "description": "Which Captapi endpoint to call. Each operation needs specific fields below (url, search query, limit, ...).",
      "editor": "select",
      "enum": [
        "youtube_transcript",
        "youtube_summarize",
        "youtube_video_details",
        "youtube_comments",
