{
  "url": "/v1/google/search",
  "method": "GET",
  "qs": {
    "q": "{{parameters.q}}",
    "country": "{{parameters.country}}",
    "language": "{{parameters.language}}",
    "limit": "{{parameters.limit}}",
    "cache": "{{parameters.cache}}"
  },
  "response": {
    "output": "{{body.data}}"
  }
}
